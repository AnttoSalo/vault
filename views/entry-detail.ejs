<%- include('partials/header') %>

<div class="page-header">
  <a href="/" class="back-link"><i class="bi bi-arrow-left"></i> Back</a>
  <div class="page-header-actions">
    <a href="/entry/<%= entry.id %>/edit" class="btn btn-ghost btn-sm"><i class="bi bi-pencil"></i> Edit</a>
    <form method="POST" action="/entry/<%= entry.id %>/delete" class="inline-form" id="delete-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-danger btn-sm" id="delete-btn"><i class="bi bi-trash3"></i> Delete</button>
    </form>
  </div>
</div>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
<% } %>

<div class="detail-card">
  <div class="detail-header">
    <div class="detail-icon">
      <% if (entry.type === 'api-key') { %><i class="bi bi-key-fill"></i>
      <% } else if (entry.type === 'database') { %><i class="bi bi-database-fill"></i>
      <% } else if (entry.type === 'ssh-key') { %><i class="bi bi-terminal-fill"></i>
      <% } else if (entry.type === 'note') { %><i class="bi bi-sticky-fill"></i>
      <% } else if (entry.type === 'ftp') { %><i class="bi bi-hdd-network-fill"></i>
      <% } else { %><i class="bi bi-lock-fill"></i>
      <% } %>
    </div>
    <div>
      <h2 class="detail-name"><%= entry.name %></h2>
      <div class="detail-badges">
        <span class="badge badge-<%= entry.category %>"><%= entry.category.replace('-', ' ') %></span>
        <span class="badge badge-type"><%= entry.type.replace('-', ' ') %></span>
        <% if (entry.tags) { %>
          <% entry.tags.split(',').map(t => t.trim()).filter(Boolean).forEach(tag => { %>
            <span class="badge badge-tag"><%= tag %></span>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <% if (entry.username) { %>
  <div class="detail-field">
    <label>Username</label>
    <div class="field-value">
      <span class="masked-value" data-value="<%= entry.username %>"><%= entry.username %></span>
      <button class="btn-icon copy-btn" data-copy="<%= entry.username %>" title="Copy"><i class="bi bi-clipboard"></i></button>
    </div>
  </div>
  <% } %>

  <div class="detail-field">
    <label>Secret</label>
    <div class="field-value">
      <span class="masked-value secret-masked" data-value="<%= entry.secret %>">••••••••••••</span>
      <button class="btn-icon toggle-vis" title="Show/hide"><i class="bi bi-eye"></i></button>
      <button class="btn-icon copy-btn" data-copy="<%= entry.secret %>" title="Copy"><i class="bi bi-clipboard"></i></button>
    </div>
  </div>

  <% if (entry.url) { %>
  <div class="detail-field">
    <label>URL / Host</label>
    <div class="field-value">
      <span class="masked-value" data-value="<%= entry.url %>"><%= entry.url %></span>
      <button class="btn-icon copy-btn" data-copy="<%= entry.url %>" title="Copy"><i class="bi bi-clipboard"></i></button>
    </div>
  </div>
  <% } %>

  <% if (entry.notes) { %>
  <div class="detail-field">
    <label>Notes</label>
    <div class="field-value notes-value">
      <pre><%= entry.notes %></pre>
    </div>
  </div>
  <% } %>

  <div class="detail-footer">
    <span>Created: <%= new Date(entry.createdAt + 'Z').toLocaleDateString() %></span>
    <span>Updated: <%= new Date(entry.updatedAt + 'Z').toLocaleDateString() %></span>
  </div>
</div>

<%- include('partials/footer') %>

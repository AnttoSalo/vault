<%- include('partials/header') %>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
<% } %>

<div class="toolbar">
  <form class="search-form" method="GET" action="/">
    <div class="search-wrap">
      <i class="bi bi-search"></i>
      <input type="text" name="search" value="<%= search %>" placeholder="Search entries...  (/ to focus)" id="search-input">
      <% if (search) { %><a href="/" class="search-clear"><i class="bi bi-x-lg"></i></a><% } %>
      <kbd class="search-kbd">Ctrl+K</kbd>
    </div>
    <input type="hidden" name="category" value="<%= category %>">
  </form>

  <div class="category-pills">
    <a href="/?search=<%= encodeURIComponent(search) %>" class="pill <%= category === 'all' ? 'active' : '' %>">All</a>
    <a href="/?category=recent&search=<%= encodeURIComponent(search) %>" class="pill <%= category === 'recent' ? 'active' : '' %>"><i class="bi bi-clock-history"></i> Recent</a>
    <% categories.forEach(c => { %>
      <a href="/?category=<%= c %>&search=<%= encodeURIComponent(search) %>" class="pill <%= category === c ? 'active' : '' %>"><%= c.replace('-', ' ') %></a>
    <% }) %>
  </div>
</div>

<% if (entries.length === 0) { %>
  <div class="empty-state">
    <i class="bi bi-shield-lock"></i>
    <p><%= search || category !== 'all' ? 'No entries match your filters.' : 'No entries yet. Add your first secret.' %></p>
    <% if (!search && category === 'all') { %>
      <a href="/new" class="btn btn-primary">Add Entry</a>
    <% } %>
  </div>
<% } else { %>
  <%
    const pinned = entries.filter(e => e.pinned);
    const unpinned = entries.filter(e => !e.pinned);
  %>
  <div class="entry-list" id="entry-list">
    <% if (pinned.length > 0 && category !== 'recent') { %>
      <% pinned.forEach(entry => { %>
        <%- include('partials/entry-card', { entry }) %>
      <% }) %>
      <% if (unpinned.length > 0) { %>
        <div class="pinned-divider"></div>
      <% } %>
    <% } %>
    <% (category === 'recent' ? entries : unpinned).forEach(entry => { %>
      <%- include('partials/entry-card', { entry }) %>
    <% }) %>
  </div>
<% } %>

<div class="footer-bar">
  <span class="entry-count"><%= entries.length %> entr<%= entries.length === 1 ? 'y' : 'ies' %></span>
  <div class="footer-actions">
    <button class="btn-icon" id="import-btn" title="Import backup"><i class="bi bi-upload"></i></button>
    <a href="/export" class="btn-icon" title="Export backup"><i class="bi bi-download"></i></a>
    <button class="btn-icon" id="shortcuts-btn" title="Keyboard shortcuts"><i class="bi bi-keyboard"></i></button>
  </div>
</div>

<!-- Import modal -->
<div class="modal-overlay" id="import-modal">
  <div class="modal-box">
    <h3>Import Backup</h3>
    <form method="POST" action="/import">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="import-dropzone" id="import-dropzone">
        <i class="bi bi-file-earmark-arrow-up"></i>
        <p>Drop a backup JSON file here or <label for="import-file" class="import-file-label">choose file</label></p>
        <input type="file" id="import-file" accept=".json" class="sr-only">
      </div>
      <textarea name="data" id="import-data" placeholder="...or paste backup JSON here" rows="4"></textarea>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" id="import-cancel">Cancel</button>
        <button type="submit" class="btn btn-primary">Import</button>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>

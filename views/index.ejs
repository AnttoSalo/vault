<%- include('partials/header') %>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
<% } %>

<div class="toolbar">
  <form class="search-form" method="GET" action="/">
    <div class="search-wrap">
      <i class="bi bi-search"></i>
      <input type="text" name="search" value="<%= search %>" placeholder="Search entries..." id="search-input">
      <% if (search) { %><a href="/" class="search-clear"><i class="bi bi-x-lg"></i></a><% } %>
    </div>
    <input type="hidden" name="category" value="<%= category %>">
  </form>

  <div class="category-pills">
    <a href="/?search=<%= encodeURIComponent(search) %>" class="pill <%= category === 'all' ? 'active' : '' %>">All</a>
    <% categories.forEach(c => { %>
      <a href="/?category=<%= c %>&search=<%= encodeURIComponent(search) %>" class="pill <%= category === c ? 'active' : '' %>"><%= c.replace('-', ' ') %></a>
    <% }) %>
  </div>
</div>

<% if (entries.length === 0) { %>
  <div class="empty-state">
    <i class="bi bi-shield-lock"></i>
    <p><%= search || category !== 'all' ? 'No entries match your filters.' : 'No entries yet. Add your first secret.' %></p>
    <% if (!search && category === 'all') { %>
      <a href="/new" class="btn btn-primary">Add Entry</a>
    <% } %>
  </div>
<% } else { %>
  <div class="entry-list">
    <% entries.forEach(entry => { %>
      <a href="/entry/<%= entry.id %>" class="entry-card">
        <div class="entry-icon">
          <% if (entry.type === 'api-key') { %><i class="bi bi-key-fill"></i>
          <% } else if (entry.type === 'database') { %><i class="bi bi-database-fill"></i>
          <% } else if (entry.type === 'ssh-key') { %><i class="bi bi-terminal-fill"></i>
          <% } else if (entry.type === 'note') { %><i class="bi bi-sticky-fill"></i>
          <% } else if (entry.type === 'ftp') { %><i class="bi bi-hdd-network-fill"></i>
          <% } else { %><i class="bi bi-lock-fill"></i>
          <% } %>
        </div>
        <div class="entry-info">
          <div class="entry-name"><%= entry.name %></div>
          <div class="entry-meta">
            <span class="badge badge-<%= entry.category %>"><%= entry.category.replace('-', ' ') %></span>
            <% if (entry.username) { %><span class="entry-user"><i class="bi bi-person-fill"></i> <%= entry.username %></span><% } %>
          </div>
        </div>
        <div class="entry-arrow"><i class="bi bi-chevron-right"></i></div>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="footer-bar">
  <span class="entry-count"><%= entries.length %> entr<%= entries.length === 1 ? 'y' : 'ies' %></span>
  <div class="footer-actions">
    <button class="btn-icon" id="import-btn" title="Import backup"><i class="bi bi-upload"></i></button>
    <a href="/export" class="btn-icon" title="Export backup"><i class="bi bi-download"></i></a>
  </div>
</div>

<!-- Import modal -->
<div class="modal-overlay" id="import-modal">
  <div class="modal-box">
    <h3>Import Backup</h3>
    <form method="POST" action="/import">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <textarea name="data" placeholder="Paste backup JSON here..." rows="6" required></textarea>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" id="import-cancel">Cancel</button>
        <button type="submit" class="btn btn-primary">Import</button>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
